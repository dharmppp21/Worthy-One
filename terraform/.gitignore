# Terraform local cache and state
.terraform/
terraform.tfstate
terraform.tfstate.*.backup
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
