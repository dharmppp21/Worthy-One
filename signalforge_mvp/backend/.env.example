# SignalForge Backend Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection (used when database persistence is enabled)
DATABASE_URL=postgresql+psycopg2://signforge:signforge@localhost:5432/signforge

# Redis connection (used for rolling windows and hot operational state)
REDIS_URL=redis://localhost:6379/0

# Kafka / Redpanda brokers (event-driven telemetry ingestion)
KAFKA_BROKERS=localhost:9092

# Application settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# For local testing without Docker infrastructure, use SQLite and disable Kafka:
# DATABASE_URL=sqlite:///./signforge.db
# KAFKA_BROKERS=  # leave empty or unset to disable Kafka and use sync processing

# For in-memory SQLite (tests only):
# DATABASE_URL=sqlite:///:memory:
